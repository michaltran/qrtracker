# ── Neon PostgreSQL ─────────────────────────────────────────────────────────
# Lấy từ: https://console.neon.tech → project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Admin ────────────────────────────────────────────────────────────────────
# Đặt chuỗi bất kỳ, giữ bí mật
ADMIN_TOKEN=your-secret-admin-token-here

# ── App URL ──────────────────────────────────────────────────────────────────
# Khi deploy Vercel: https://your-app.vercel.app
# Local dev: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Dùng trong dashboard để không phải nhập token mỗi lần (tùy chọn)
NEXT_PUBLIC_ADMIN_TOKEN=your-secret-admin-token-here
